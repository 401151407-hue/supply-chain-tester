{
  "name": "supply-chain-tester",
  "productName": "SupplyChainTester",
  "version": "0.2.8",
  "description": "供应链测试工具 - API测试、业务流程测试、AI自动执行与报告生成",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "node scripts/patch-blockmap.mjs",
    "predist": "node -e \"const{rmSync,readdirSync}=require('fs');const d='dist';readdirSync(d).forEach(f=>{if(f.startsWith('SupplyChainTester-')||f==='mac'||f==='mac-arm64')rmSync(d+'/'+f,{recursive:true})})\" 2>/dev/null || true",
    "dist": "npm run build && npx --yes electron-builder --config electron-builder.config.cjs --publish never",
    "prerelease": "npm run predist",
    "release": "npm run build && npx --yes electron-builder --config electron-builder.config.cjs --publish always",
    "setup-python": "powershell -ExecutionPolicy Bypass -File scripts/setup-python.ps1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.544.0",
    "playwright": "^1.61.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
